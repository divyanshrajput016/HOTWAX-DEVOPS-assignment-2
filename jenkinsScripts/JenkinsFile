pipeline {
    agent any

    environment {
        MONGO_URI = credentials('MONGO_URI')
        GEMINI_API_KEY = credentials('GOOGLE_API_KEY')
        JWT_SECRET = credentials('JWT_SECRET')

        REPO_URL = 'https://github.com/divyanshrajput016/AI-powered-resume-analyser.git'
        BACKEND_PORT = '3000'
        FRONTEND_PORT = '5000'
    }

    stages {
        stage('Clone') {
            steps {
                git branch: 'main', url: "${REPO_URL}"
            }
        }

        stage('Create .env') {
            steps {
                sh '''
                set -e

                PUBLIC_IP=localhost

                cat > .env <<EOF
MONGO_URI=$MONGO_URI
GEMINI_API_KEY=$GEMINI_API_KEY
JWT_SECRET=$JWT_SECRET
NEXT_PUBLIC_API_URL=http://$PUBLIC_IP:$BACKEND_PORT
FRONTEND_URL=http://$PUBLIC_IP:$FRONTEND_PORT
EOF

                echo ".env created"
                grep -E "NEXT_PUBLIC_API_URL|FRONTEND_URL" .env
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker compose down
                docker compose up -d --build --force-recreate
                '''
            }
        }
    }
}