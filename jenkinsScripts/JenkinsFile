pipeline {
    agent any

    environment {
        MONGO_URI = credentials('MONGO_URI')
        GEMINI_API_KEY = credentials('GEMINI_API_KEY')
        JWT_SECRET = credentials('JWT_SECRET')
        MONGO_INITDB_ROOT_USERNAME = credentials('MONGO_INITDB_ROOT_USERNAME')
        MONGO_INITDB_ROOT_PASSWORD = credentials('MONGO_INITDB_ROOT_PASSWORD')

        REPO_URL = 'https://github.com/divyanshrajput016/AI-powered-resume-analyser.git'

        BACKEND_PORT = '3000'
        FRONTEND_PORT = '5000'
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main', url: "${REPO_URL}"
            }
        }

        stage('Create Environment Files') {
            steps {
                sh '''
                set -e

                PUBLIC_IP=$(curl -s http://checkip.amazonaws.com)

                echo "Creating env files..."

                cat > .env <<EOF
MONGO_URI=mongodb://$MONGO_INITDB_ROOT_USERNAME:$MONGO_INITDB_ROOT_PASSWORD@mongodb:27017/resume_analyser?authSource=admin
GEMINI_API_KEY=$GEMINI_API_KEY
JWT_SECRET=$JWT_SECRET
MONGO_INITDB_ROOT_USERNAME=$MONGO_INITDB_ROOT_USERNAME
MONGO_INITDB_ROOT_PASSWORD=$MONGO_INITDB_ROOT_PASSWORD
NEXT_PUBLIC_API_URL=http://$PUBLIC_IP:$BACKEND_PORT
FRONTEND_URL=http://$PUBLIC_IP:$FRONTEND_PORT
EOF

                cp .env client/.env
                cp .env server/.env

                echo "ENV FILE CREATED SUCCESSFULLY"
                '''
            }
        }

        stage('Docker Deploy') {
            steps {
                sh '''
                docker compose down || true

                docker compose build --no-cache

                docker compose up -d --force-recreate
                '''
            }
        }

        stage('Check Running Containers') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
